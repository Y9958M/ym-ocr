# ── ym-ocr 环境配置 ──
# 复制为 .env 后按需修改

# 服务
YM_OCR_HOST=127.0.0.1
YM_OCR_PORT=8001
YM_OCR_API_KEY=请替换为你的共享密钥

# 推理
# 留空则自动探测（有 GPU 用 gpu:0，否则 cpu）
OCR_DEVICE=
# 模型档位：PP-OCRv6_medium（默认）| PP-OCRv6_small | PP-OCRv6_tiny
OCR_MODEL=PP-OCRv6_medium
# 本地模型根目录（git 排除）；首次启动自动下载到此
OCR_MODEL_DIR=models
# 推理并发上限，GPU 防爆
OCR_MAX_CONCURRENT=2

# PDF
OCR_PDF_MAX_PAGES=50
OCR_PDF_RENDER_SCALE=2.0

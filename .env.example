# ── ym-ocr 环境配置 ──
# 复制为 .env 后按需修改

# 服务
YM_OCR_HOST=127.0.0.1
YM_OCR_PORT=8001
YM_OCR_API_KEY=请替换为你的共享密钥

# 推理
# 留空则自动探测（有 GPU 用 gpu:0，否则 cpu）
OCR_DEVICE=
# 模型档位：PP-OCRv6_small | PP-OCRv6_medium | PP-OCRv6_tiny
# det/rec 未单独指定时均跟随 OCR_MODEL
OCR_MODEL=PP-OCRv6_small
# 检测/识别可混用（留空=跟随 OCR_MODEL）；截图+显存紧推荐 small det + medium rec
OCR_DET_MODEL=PP-OCRv6_small
OCR_REC_MODEL=PP-OCRv6_medium
# 本地模型根目录（git 排除）；首次启动自动下载到此
OCR_MODEL_DIR=models
# 检测最长边上限（像素），过大图降采样以省显存
OCR_DET_LIMIT_SIDE_LEN=1280
# 推理并发上限，GPU 防爆
OCR_MAX_CONCURRENT=2

# PDF
OCR_PDF_MAX_PAGES=50
OCR_PDF_RENDER_SCALE=1.5
